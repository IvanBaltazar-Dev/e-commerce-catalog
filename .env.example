NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only. Never expose this with NEXT_PUBLIC_ and never use it in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXT_PUBLIC_SITE_URL=http://localhost:3000
CATALOG_DEFAULT_WHATSAPP=+51963463550

# Solo desarrollo local del PDF (opcional). En serverless (Vercel) se usa
# @sparticuz/chromium automáticamente. En local, el generador usa el Chromium del paquete
# `puppeteer`; si no está descargado, ejecuta `npx puppeteer browsers install chrome` o
# apunta aquí un Chrome/Edge del sistema, p. ej.:
# PUPPETEER_EXECUTABLE_PATH=C:/Program Files (x86)/Microsoft/Edge/Application/msedge.exe
